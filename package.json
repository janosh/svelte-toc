{
  "name": "svelte-toc",
  "description": "Sticky responsive table of contents component written in Svelte",
  "author": "Janosh Riebesell <janosh.riebesell@gmail.com>",
  "homepage": "https://janosh.github.io/svelte-toc",
  "repository": "https://github.com/janosh/svelte-toc",
  "license": "MIT",
  "version": "0.6.3",
  "type": "module",
  "scripts": {
    "package": "svelte-package",
    "prepublishOnly": "pnpm package"
  },
  "svelte": "./dist/index.js",
  "bugs": "https://github.com/janosh/svelte-toc/issues",
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.53.4",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@wooorm/starry-night": "^3.9.0",
    "eslint": "^10.0.3",
    "eslint-plugin-svelte": "^3.15.2",
    "jsdom": "^28.1.0",
    "mdsvex": "^0.12.7",
    "svelte-check-rs": "^0.9.5",
    "svelte-multiselect": "^11.6.3",
    "svelte2tsx": "^0.7.52",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "svelte",
    "toc",
    "table of contents",
    "component",
    "navigation",
    "headings",
    "sidebar"
