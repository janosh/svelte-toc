{
  "name": "svelte-toc",
  "version": "0.7.0",
  "description": "Sticky responsive table of contents component written in Svelte",
  "keywords": [
    "component",
    "headings",
    "navigation",
    "sidebar",
    "svelte",
    "table of contents",
    "toc"
  ],
  "homepage": "https://janosh.github.io/svelte-toc",
  "bugs": "https://github.com/janosh/svelte-toc/issues",
  "license": "MIT",
  "author": "Janosh Riebesell <janosh.riebesell@gmail.com>",
  "repository": "https://github.com/janosh/svelte-toc",
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "svelte": "./dist/index.js",
  "exports": {
    "./Toc.svelte": {
      "types": "./dist/Toc.svelte.d.ts",
      "svelte": "./dist/Toc.svelte",
      "default": "./dist/Toc.svelte"
    },
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vp test --run && playwright test",
    "package": "svelte-package",
    "prepublishOnly": "npm run package",
    "changelog": "npx tsx https://github.com/janosh/workflows/raw/refs/heads/main/scripts/make-release-notes.ts"
  },
  "devDependencies": {
    "@janosh/vite-config": "github:janosh/dotfiles",
    "@playwright/test": "1.60.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.61.1",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@vitest/coverage-v8": "^4.1.7",
    "@wooorm/starry-night": "^3.9.0",
    "abstract-syntax-tree": "^2.22.0",
    "acorn": "^8.16.0",
    "jsdom": "^29.1.1",
    "mdsvex": "^0.12.7",
    "svelte": "^5.55.10",
    "svelte-check": "^4.4.8",
    "svelte-multiselect": "^11.7.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plus": "latest",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "packageManager": "pnpm@11.5.0"
}
