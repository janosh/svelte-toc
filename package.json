{
  "name": "svelte-toc",
  "version": "0.6.3",
  "description": "Sticky responsive table of contents component written in Svelte",
  "keywords": [
    "component",
    "headings",
    "navigation",
    "sidebar",
    "svelte",
    "table of contents",
    "toc"
  ],
  "homepage": "https://janosh.github.io/svelte-toc",
  "bugs": "https://github.com/janosh/svelte-toc/issues",
  "license": "MIT",
  "author": "Janosh Riebesell <janosh.riebesell@gmail.com>",
  "repository": "https://github.com/janosh/svelte-toc",
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "svelte": "./dist/index.js",
  "exports": {
    "./Toc.svelte": {
      "types": "./dist/Toc.svelte.d.ts",
      "svelte": "./dist/Toc.svelte",
      "default": "./dist/Toc.svelte"
    },
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "test": "vp test --run && playwright test",
    "check": "vp check",
    "lint": "vp lint",
    "fmt": "vp fmt --write",
    "package": "svelte-package",
    "prepublishOnly": "npm run package",
    "changelog": "npx tsx https://github.com/janosh/workflows/raw/refs/heads/main/scripts/make-release-notes.ts"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.53.4",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@wooorm/starry-night": "^3.9.0",
    "abstract-syntax-tree": "^2.22.0",
    "acorn": "^8.16.0",
    "jsdom": "^28.1.0",
    "mdsvex": "^0.12.7",
    "svelte": "^5.53.12",
    "svelte-multiselect": "^11.6.3",
    "svelte-preprocess": "^6.0.3",
    "typescript": "^5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "overrides": {
    "svelte": "$svelte",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  }
}
